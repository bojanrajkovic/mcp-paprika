{
  "name": "@bojanrajkovic/mcp-paprika",
  "version": "1.0.3",
  "description": "MCP server for Paprika recipe manager",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bojanrajkovic/mcp-paprika"
  },
  "bin": {
    "mcp-paprika": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint --deny-warnings src/",
    "lint:fix": "oxlint --fix src/",
    "prepare": "lefthook install",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cockatiel": "^3.2.1",
    "dotenv": "^17.4.2",
    "env-paths": "^4.0.0",
    "luxon": "^3.7.2",
    "mitt": "^3.0.1",
    "neverthrow": "^8.2.0",
    "parse-duration": "^2.1.6",
    "vectra": "^0.12.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@tsconfig/node24": "^24.0.4",
    "@tsconfig/strictest": "^2.0.8",
    "@types/luxon": "^3.7.1",
    "@types/node": "^24.12.2",
    "@vitest/coverage-v8": "^4.1.5",
    "fast-check": "^4.7.0",
    "lefthook": "^2.1.6",
    "msw": "^2.13.6",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "tsx": "^4.21",
    "type-fest": "^5.6.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=24.14.1"
  },
  "packageManager": "pnpm@10.33.0"
}
